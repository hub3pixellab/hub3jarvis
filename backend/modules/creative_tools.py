from routes.brain_routes import router as brain_router
from routes.learning_routes import router as learning_router
from routes.vault_routes import router as vault_router
from routes.integration_routes import router as integration_router

load_dotenv()

@asynccontextmanager
async def lifespan(app: FastAPI):
    await db_manager.connect()
    print("=" * 60)
    print("  HUB3 JARVIS v4.2 - Backend Online")
    print("  MongoDB conectado | Idioma: pt-BR")
    print("  Modo: Portable (HD Externo) + Self-Hosted")
    print("  Modulos: Consensus | Second Brain | Self-Learning")
    print("  Vault: Knowledge Vault ATIVO")
    print("  Integracoes: GitHub | Postiz | 28 Creative Tools")
    print("=" * 60)
    yield
    await db_manager.disconnect()
    print("Hub3 JARVIS - Backend encerrado")

app = FastAPI(title="Hub3 JARVIS", version="4.2.0", lifespan=lifespan)

