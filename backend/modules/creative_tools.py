app.include_router(integration_router, prefix="/integration", tags=["Integracoes"])

@app.websocket("/ws")
async def websocket_endpoint(websocket: WebSocket):
    await websocket.accept()
    try:
        while True:
            data = await websocket.receive_text()
            await websocket.send_json({"status": "connected", "message": data, "timestamp": str(datetime.now())})
    except WebSocketDisconnect:
        print("Cliente WebSocket desconectado")

